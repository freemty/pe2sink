# Optional local FLUX.1-dev checkpoint root.
# The demo checks PE2SINK_HF_PATH/black-forest-labs/FLUX.1-dev first.
PE2SINK_HF_PATH=/path/to/huggingface/cache

# Optional root with huggingface/ or modelscope/ subdirectories.
PE2SINK_DATA_ROOT=/path/to/model/root

# Optional Hugging Face token for gated model access.
HF_TOKEN=
